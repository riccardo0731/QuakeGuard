{
  "extends": ["@commitlint/config-conventional"],
  "rules": {
    "body-max-line-length": [0, "always", 100],
    "footer-max-line-length": [0, "always", 100],
    "type-enum": [
      2,
      "always",
      ["feat", "fix", "sec", "test", "refactor", "chore", "docs", "ci"]
    ],
    "scope-enum": [
      2,
      "always",
      ["backend", "frontend", "iot", "ci", "deps", "core", "style"]
    ]
  }
}
