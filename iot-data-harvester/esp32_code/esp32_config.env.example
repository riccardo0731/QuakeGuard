# ==============================================================================
# QUAKEFINDER FIRMWARE CONFIGURATION (NGROK DEVELOPMENT)
# File: esp32_config.env
# Description: Environment variables injected into the firmware during build.
# Target Environment: Remote / ngrok Tunnel
# ==============================================================================

# --- Network Connectivity (WiFi) ---
# SSID and Password for the local access point.
WIFI_SSID="Mockup_Lab_WiFi_5G"
WIFI_PASS="LabNetworkPass123!"

# --- Backend Connection (HTTP via ngrok) ---
# Target Host Domain.
# NOTE: Do not include "http://" or "https://". Just the domain name provided by ngrok.
# Example: f4k3-123-45-67.ngrok-free.app
SERVER_HOST="your-tunnel-id.ngrok-free.app"

# Target Port.
# Use 80 for standard HTTP routing through ngrok, or 443 if your ESP32 is configured for Secure/HTTPS requests.
SERVER_PORT=80

# API Endpoint Path.
SERVER_PATH="/misurations/"

# --- Device Identity ---
# The unique integer ID corresponding to the 'misurators' table in the database.
# Ensure this ID is registered in the local backend database before operation.
SENSOR_ID=42

# ==============================================================================
# SECURITY & CRYPTOGRAPHY NOTE
# ==============================================================================
# Cryptographic keys (Private/Public ECDSA pairs) are NOT configured in this file.
# Keys are automatically generated by the firmware upon first initialization
# and stored securely in the device's NVS (Non-Volatile Storage) partition.
#
# Check the Serial Monitor output on boot to retrieve the Public Key.
ENROLLMENT_TOKEN=quake_enroll_mk99283